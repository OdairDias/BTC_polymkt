# Polymarket — BTC Up/Down 5 minutos (valores oficiais Gamma API, mar/2026)
POLYMARKET_SERIES_ID=10684
POLYMARKET_SERIES_SLUG=btc-up-or-down-5m
POLYMARKET_AUTO_SELECT_LATEST=true

# Alinhar janela de TA / “time left” ao timeframe do mercado (5 ou 15)
CANDLE_WINDOW_MINUTES=5

# Opcional: fixar um mercado específico em vez do último da série
# POLYMARKET_SLUG=btc-updown-5m-...

# Chainlink fallback (recomendado)
# POLYGON_RPC_URL=https://polygon-rpc.com
# POLYGON_RPC_URLS=https://polygon-rpc.com,https://rpc.ankr.com/polygon
# POLYGON_WSS_URLS=wss://polygon-bor-rpc.publicnode.com

# ── Estratégia paper (últimos N min: compara mid UP vs DOWN; Postgres) ──
# STRATEGY_ENABLED=false
# STRATEGY_DRY_RUN=true
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# STRATEGY_ENTRY_MINUTES_LEFT=2
# STRATEGY_PRICE_EPSILON=0.001
# STRATEGY_NOTIONAL_USD=1
# STRATEGY_OUTCOME_LAST_SECONDS=5
# STRATEGY_TARGET_PRICE=0.20

# Guardas de risco (anti-quebra + assimetria favorÃ¡vel)
# STRATEGY_RISK_GUARDS_ENABLED=true
# STRATEGY_MAX_CONSECUTIVE_LOSSES=6
# STRATEGY_ROLLING_LOSS_HOURS=24
# STRATEGY_MAX_ROLLING_LOSS_USD=12
# STRATEGY_MIN_PAYOUT_MULTIPLE=2.5
# STRATEGY_MAX_ENTRY_PRICE=0.30
# Multi-estratÃ©gia em paralelo (dry-run/live), cada key decide separadamente.
# Exemplo com 3 perfis:
# STRATEGY_VARIANTS_JSON=[{"key":"sniper_45s","decisionMode":"sniper_v2"},{"key":"main_2m","decisionMode":"main_2m_mid","entryMinutesLeft":2.0,"priceEpsilon":0.001,"notionalUsd":1},{"key":"safe_90s","decisionMode":"sniper_v2","entryMinutesLeft":0.9,"targetEntryPrice":0.25,"notionalUsd":0.75,"minPayoutMultiple":2.0}]
# Se live estiver armado, apenas essa key pode enviar ordem real:
# STRATEGY_LIVE_STRATEGY_KEY=cheap_1h_tp45

# ── Conta real CLOB (só com STRATEGY_DRY_RUN=false E STRATEGY_LIVE_ARMED=true) ──
# STRATEGY_LIVE_ARMED=false
# Logs extra no stderr + raw_response JSON mais rico (Railway): STRATEGY_LIVE_DEBUG=true
# POLYMARKET_PRIVATE_KEY=0x...
# POLYMARKET_CHAIN_ID=137
# EOA pura (MetaMask/Phantom só Polygon): SIGNATURE_TYPE=0, FUNDER vazio.
# Conta Polymarket com proxy (muito comum com Phantom/email): SIGNATURE_TYPE=1 e FUNDER = address do perfil
# (onde está o saldo no site). Ver doc + guia: https://gist.github.com/Archetapp/7680adabc48f812a561ca79d73cbac69
# POLYMARKET_SIGNATURE_TYPE=0
# POLYMARKET_FUNDER_ADDRESS=

# Opcional — Relayer / Builder API (Polymarket Settings): injeta POLY_BUILDER_* no POST /order (ClobClient).
# O SDK precisa de key + secret + passphrase. No UI aparecem ao criar a key (guarda já — mostram uma vez).
# RELAYER_API_KEY_ADDRESS=...        # campo "key" (id da API ou valor que o site mostra para o endereço/key)
# RELAYER_API_SECRET=...             # secret
# RELAYER_API_PASSPHRASE=...         # passphrase
# Ou, em vez de SECRET+PASSPHRASE, um único RELAYER_API_KEY com JSON:
# RELAYER_API_KEY={"secret":"...","passphrase":"..."}
